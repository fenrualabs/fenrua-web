{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "installCommand": "npm ci --omit=dev",
  "buildCommand": "npm run build:release",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self'; connect-src 'self'; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'"
        },
        {
          "key": "Referrer-Policy",
          "value": "no-referrer"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/docs/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/docs/archive/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/genesis",
      "destination": "/audit",
      "permanent": true
    },
    {
      "source": "/regression",
      "destination": "/audit",
      "permanent": true
    },
    {
      "source": "/docs/SECURITY_AUDIT_LOG.md",
      "destination": "/docs/archive/2026-07-13/SECURITY_AUDIT_LOG.md",
      "permanent": true
    },
    {
      "source": "/docs/GENESIS_MANIFEST.md",
      "destination": "/docs/archive/2026-07-13/GENESIS_MANIFEST.md",
      "permanent": true
    },
    {
      "source": "/docs/REGRESSION_HISTORY.md",
      "destination": "/docs/archive/2026-07-13/REGRESSION_HISTORY.md",
      "permanent": true
    },
    {
      "source": "/docs/audit-report.json",
      "destination": "/docs/archive/2026-07-13/audit-report.json",
      "permanent": true
    },
    {
      "source": "/docs/DEPLOYMENT.md",
      "destination": "/docs/archive/2026-07-13/DEPLOYMENT.md",
      "permanent": true
    },
    {
      "source": "/docs/FENRUA_CONTRACT_EVIDENCE_REFRESH_BOUNDARY.md",
      "destination": "/docs/archive/2026-07-13/FENRUA_CONTRACT_EVIDENCE_REFRESH_BOUNDARY.md",
      "permanent": true
    },
    {
      "source": "/docs/FENRUA_PUBLIC_CLAIM_EVIDENCE_REGISTER.md",
