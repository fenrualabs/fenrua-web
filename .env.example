# Server-only public-observation gateway configuration. Do not prefix any of
# these names with NEXT_PUBLIC and never commit real values.
FENRUA_OBSERVATION_GATEWAY_URL=
FENRUA_OBSERVATION_READ_TOKEN=

# This is intentionally public verification metadata, served only from
# /api/chain-observation-key. Supply either the raw 32-byte Ed25519 public key
# or SPKI DER as base64/base64url; the endpoint publishes canonical SPKI DER
# base64url. It must match the signing key used by the private watcher/gateway.
FENRUA_OBSERVATION_PUBLIC_KEY_B64=
FENRUA_OBSERVATION_KEY_ID=fenchain-978-observation-v1

# Chain N521 uses its own independently signed bounded observation path. Leave
# these unset until that watcher, gateway, and public verification key exist;
# the website will show "Awaiting signed observation" rather than invent data.
FENRUA_N521_OBSERVATION_GATEWAY_URL=
FENRUA_N521_OBSERVATION_READ_TOKEN=
FENRUA_N521_OBSERVATION_PUBLIC_KEY_B64=
FENRUA_N521_OBSERVATION_KEY_ID=fenchain-521-observation-v1
