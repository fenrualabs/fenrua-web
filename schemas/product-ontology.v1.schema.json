{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fenrua.ai/schemas/product-ontology.v1.schema.json",
  "title": "Fenrua product ontology v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "lastReviewed",
    "sourceReferences",
    "entities",
    "legacyTermPolicy"
  ],
  "properties": {
    "schemaVersion": { "const": "fenrua.product-ontology.v1" },
    "lastReviewed": { "type": "string", "format": "date" },
    "sourceReferences": {
      "type": "object",
      "additionalProperties": false,
      "required": ["companyIdentityId", "siteEvidenceId", "documentRegisterId"],
      "properties": {
        "companyIdentityId": { "type": "string", "minLength": 1 },
        "siteEvidenceId": { "type": "string", "minLength": 1 },
        "documentRegisterId": { "type": "string", "minLength": 1 }
      }
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "canonicalName",
          "entityType",
          "status",
          "category",
          "definition",
          "aliases",
          "deprecatedAliases",
          "prohibitedAmbiguities",
          "replacementId",
          "effectiveDate",
          "publicRoutes",
          "owner",
          "evidenceIds"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^fenrua\\.[a-z0-9-]+$" },
          "canonicalName": { "type": "string", "minLength": 1 },
          "entityType": {
            "enum": [
              "organisation",
              "product",
              "subsystem",
              "capability",
              "research-family",
              "observation-source"
            ]
          },
          "status": { "enum": ["current", "deprecated", "historical", "planned"] },
          "category": { "type": "string", "minLength": 1 },
          "definition": { "type": "string", "minLength": 1 },
          "aliases": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "deprecatedAliases": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "prohibitedAmbiguities": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "replacementId": { "type": ["string", "null"] },
          "effectiveDate": { "type": "string", "format": "date" },
          "publicRoutes": { "type": "array", "items": { "type": "string", "pattern": "^/" } },
          "owner": { "type": "string", "minLength": 1 },
          "evidenceIds": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "legacyTermPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scanRoot", "terms"],
      "properties": {
        "scanRoot": { "const": "public" },
        "terms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["term", "status", "replacementId", "allowances"],
            "properties": {
              "term": { "type": "string", "minLength": 1 },
              "status": { "enum": ["deprecated", "historical"] },
              "replacementId": { "type": ["string", "null"] },
              "allowances": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["file", "context", "claimId", "expectedMatches"],
                  "properties": {
                    "file": { "type": "string", "pattern": "^public/(?:[^*]+/)*index\\.html$" },
                    "context": { "type": "string", "minLength": 1 },
                    "claimId": { "type": "string", "minLength": 1 },
                    "expectedMatches": { "type": "integer", "minimum": 1 }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
