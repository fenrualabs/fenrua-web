{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fenrua.ai/schemas/assurance-language.v1.schema.json",
  "title": "Fenrua assurance language v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "lastReviewed", "sourceReferences", "contracts", "contentScan"],
  "properties": {
    "schemaVersion": { "const": "fenrua.assurance-language.v1" },
    "lastReviewed": { "type": "string", "format": "date" },
    "sourceReferences": {
      "type": "object",
      "additionalProperties": false,
      "required": ["companyIdentityId", "siteEvidenceId", "documentRegisterId"],
      "properties": {
        "companyIdentityId": { "type": "string", "minLength": 1 },
        "siteEvidenceId": { "type": "string", "minLength": 1 },
        "documentRegisterId": { "type": "string", "minLength": 1 }
      }
    },
    "contracts": {
      "type": "array",
      "minItems": 14,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["term", "level", "permittedEvidenceClasses", "requires", "prohibitedWithout", "doesNotMean", "scan"],
        "properties": {
          "term": { "type": "string", "minLength": 1 },
          "level": { "type": "integer", "minimum": 0, "maximum": 100 },
          "permittedEvidenceClasses": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "requires": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "prohibitedWithout": { "type": "string", "minLength": 1 },
          "doesNotMean": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "scan": { "type": "boolean" }
        }
      }
    },
    "contentScan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "allowances"],
      "properties": {
        "root": { "const": "public" },
        "allowances": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["files", "term", "context", "claimId", "contextType", "minimumMatches", "maximumMatches"],
            "properties": {
              "files": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "pattern": "^public/(?:[^*]+/)*index\\.html$" }
              },
              "term": { "type": "string", "minLength": 1 },
              "context": { "type": "string", "minLength": 1 },
              "claimId": { "type": "string", "pattern": "^claim\\." },
              "contextType": { "enum": ["claim", "explanatory", "historical", "fixture"] },
              "minimumMatches": { "type": "integer", "minimum": 1 },
              "maximumMatches": { "type": ["integer", "null"], "minimum": 1 }
            }
          }
        }
      }
    }
  }
}
