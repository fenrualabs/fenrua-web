{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fenrua.ai/schemas/evidence-taxonomy.v1.schema.json",
  "title": "Fenrua evidence taxonomy v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "lastReviewed", "sourceReferences", "classes", "evidenceRecords"],
  "properties": {
    "schemaVersion": { "const": "fenrua.evidence-taxonomy.v1" },
    "lastReviewed": { "type": "string", "format": "date" },
    "sourceReferences": {
      "type": "object",
      "additionalProperties": false,
      "required": ["companyIdentityId", "siteEvidenceId", "documentRegisterId"],
      "properties": {
        "companyIdentityId": { "type": "string", "minLength": 1 },
        "siteEvidenceId": { "type": "string", "minLength": 1 },
        "documentRegisterId": { "type": "string", "minLength": 1 }
      }
    },
    "classes": {
      "type": "array",
      "minItems": 11,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "purpose",
          "acceptedSources",
          "authority",
          "integrityMethod",
          "freshnessModel",
          "expiry",
          "retention",
          "revocation",
          "supersession",
          "disclosureBoundary",
          "verificationMethod",
          "doesNotProve",
          "permittedAssuranceVerbs"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "acceptedSources": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "authority": { "type": "string", "minLength": 1 },
          "integrityMethod": { "type": "string", "minLength": 1 },
          "freshnessModel": { "type": "string", "minLength": 1 },
          "expiry": { "type": "string", "minLength": 1 },
          "retention": { "type": "string", "minLength": 1 },
          "revocation": { "type": "string", "minLength": 1 },
          "supersession": { "type": "string", "minLength": 1 },
          "disclosureBoundary": { "type": "string", "minLength": 1 },
          "verificationMethod": { "type": "string", "minLength": 1 },
          "doesNotProve": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "permittedAssuranceVerbs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "evidenceRecords": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "evidenceClassIds", "sourcePath", "documentRegisterId", "status", "scope"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
          "evidenceClassIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "sourcePath": { "type": "string", "minLength": 1 },
          "documentRegisterId": { "type": ["string", "null"] },
          "status": { "enum": ["current", "historical", "superseded", "archived"] },
          "scope": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
