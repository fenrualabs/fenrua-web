{
  "schemaVersion": "fenrua.design-tokens.v1",
  "status": "active",
  "owner": "public-platform",
  "lastReviewed": "2026-07-14",
  "description": "Canonical public-interface tokens. styles.tokens.css is generated from this file; authored styles consume custom properties rather than repeating token values.",
  "tokens": {
    "surface-0": "#080a0b",
    "surface-1": "#101315",
    "surface-2": "#171b1e",
    "surface-3": "#20262a",
    "surface-security-notice": "#3a1518",
    "line-subtle": "#293136",
    "line-strong": "#475158",
    "text-primary": "#f2f5f4",
    "text-secondary": "#b6c0bc",
    "text-muted": "#8d9894",
    "signal-info": "#79b8ff",
    "signal-pass": "#63d297",
    "signal-warn": "#f0c36a",
    "signal-fail": "#ff7a7a",
    "signal-paused": "#b6a0ff",
    "text-on-signal-pass": "#07130b",
    "surface-code": "#0b0f0d",
    "surface-control": "#101515",
    "font-mono": "\"IBM Plex Mono\", \"JetBrains Mono\", \"SFMono-Regular\", Consolas, \"Liberation Mono\", monospace",
    "font-ui": "system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
    "space-1": "0.25rem",
    "space-2": "0.5rem",
    "space-3": "0.75rem",
    "space-4": "1rem",
    "space-5": "1.5rem",
    "space-6": "2rem",
    "radius-sm": "2px",
    "radius-md": "4px",
    "radius-lg": "6px",
    "content-max": "90rem",
    "content-mobile-gutter": "1rem",
    "shadow-panel": "0 1px 0 rgb(255 255 255 / 0.03)",
    "duration-fast": "160ms",
    "duration-standard": "240ms"
  },
  "aliases": {
    "bg": "var(--surface-0)",
    "panel": "var(--surface-1)",
    "panel-2": "var(--surface-2)",
    "line": "var(--line-subtle)",
    "text": "var(--text-primary)",
    "muted": "var(--text-secondary)",
    "dim": "var(--text-muted)",
    "green": "var(--signal-pass)",
    "blue": "var(--signal-info)",
    "amber": "var(--signal-warn)",
    "red": "var(--signal-fail)",
    "shadow": "var(--shadow-panel)",
    "max": "var(--content-max)",
    "space-mobile": "var(--content-mobile-gutter)"
  }
}
